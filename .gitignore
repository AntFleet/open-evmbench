secrets/

# Upstream source cache (pinned, regenerable — see docs/UPSTREAM_PIN.md)
upstream/

# Audit-source cache (regenerable via scripts/fetch_audit_sources.py)
audit_sources/
audit_sources_*/

# Tooling session state
.omc/
.omx/
.claude/

# Foundry / Anvil
cache/
broadcast/
out/

# Task artifacts (cached, regenerable, often large)
tasks/*/upstream_cache/
tasks/*/.forge-cache/

# Fleet auditor + judge intermediate outputs (large, regenerable, never submitted directly)
runs/

# Generated receipts (kept in receipts/published/ when official)
receipts/scratch/
receipts/local/

# Logs
*.log
logs/

# Coverage
.coverage
htmlcov/
coverage.xml
