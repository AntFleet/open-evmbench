+    /**
+     * @dev Helper function to check if two items have the same type and token.
+     *
+     * @param left  Item to compare.
+     * @param right Item to compare against.
+     *
+     * @return Whether the items match.
+     */
+    function _sameItem(
+        Item memory left,
+        Item memory right
+    ) internal pure returns (bool) {
+        return
+            left.itemType == right.itemType &&
+            left.token == right.token &&
+            left.identifier == right.identifier;
+    }
+
+    /**
+     * @dev Helper function to check if an execution matches an item.
+     *
+     * @param execution         Execution performed by Seaport.
+     * @param item              Item expected to be fulfilled.
+     * @param expectedRecipient Address expected to receive the item.
+     *
+     * @return Whether the execution matches the item.
+     */
+    function _executionMatchesItem(
+        ReceivedItem memory execution,
+        Item memory item,
+        address expectedRecipient
+    ) internal pure returns (bool) {
+        if (
+            execution.token != item.token ||
+            execution.identifier != item.identifier ||
+            execution.recipient != expectedRecipient
+        ) {
+            return false;
+        }
+
+        if (item.isERC20()) {
+            return execution.isERC20();
+        } else if (item.isERC721()) {
+            return execution.isERC721();
+        } else {
+            return execution.isERC1155();
+        }
+    }
+
+    /**
+     * @dev Helper function to get the recipient expected to receive an item.
+     *
+     * @param item               Item expected to be fulfilled.
+     * @param expectedRentalSafe Address which should receive rental assets.
+     *
+     * @return Expected recipient for the item.
+     */
+    function _expectedRecipientForItem(
+        Item memory item,
+        address expectedRentalSafe
+    ) internal view returns (address) {
+        if (item.isERC20()) {
+            return address(ESCRW);
+        } else {
+            return expectedRentalSafe;
+        }
+    }
+
+    /**
+     * @dev Helper function to check that an expected item was fulfilled.
+     *
+     * @param executions         Each execution that was performed by Seaport.
+     * @param items              Items expected to be fulfilled.
+     * @param item               Item to check.
+     * @param expectedRentalSafe Address which should receive rental assets.
+     */
+    function _checkExpectedExecution(
+        ReceivedItem[] memory executions,
+        Item[] memory items,
+        Item memory item,
+        address expectedRentalSafe
+    ) internal view {
+        address expectedRecipient = _expectedRecipientForItem(
+            item,
+            expectedRentalSafe
+        );
+        uint256 expectedAmount;
+        uint256 fulfilledAmount;
+
+        for (uint256 i = 0; i < items.length; ++i) {
+            if (_sameItem(items[i], item)) {
+                expectedAmount += items[i].amount;
+            }
+        }
+
+        for (uint256 i = 0; i < executions.length; ++i) {
+            if (_executionMatchesItem(executions[i], item, expectedRecipient)) {
+                fulfilledAmount += executions[i].amount;
+            }
+        }
+
+        if (fulfilledAmount < expectedAmount) {
+            revert Errors.CreatePolicy_IncompleteExecution(
+                item.itemType,
+                item.token,
+                item.identifier,
+                expectedAmount,
+                fulfilledAmount,
+                expectedRecipient
+            );
+        }
+    }
+
